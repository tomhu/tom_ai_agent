# tom_ai_agent 配置示例（设计文档 docs/agent-design.md §9.2 的 M1-M3 子集）
agent:
  data_dir: /var/lib/tom_ai_agent
  log_level: info          # debug/info/warn/error
  asset_id: ""             # M2 注册流程签发；当前可手工指定便于联调

uplink:
  mode: stdout             # stdout | http （grpc 待 proto 冻结后接入）
  addr: ""                 # mode=http 时必填，如 http://192.168.70.1:18080

collectors:
  cpu:     { enabled: true, interval: 10s }
  memory:  { enabled: true, interval: 10s }
  load:    { enabled: true, interval: 10s }
  diskcap: { enabled: true, interval: 60s }
  net:     { enabled: true, interval: 10s }

reporter:
  buffer_size: 10000
  batch_size: 500
  batch_interval: 1s
  wal:
    enabled: true            # 可靠队列(results/audit)持久化
    max_mb: 100              # 单队列磁盘配额
    metrics_fallback: true   # 指标发送失败时落 WAL 兜底

watchdog:
  rss_soft_mb: 150           # 软限：进入降级(暂停非关键采集器+GC)
  rss_hard_mb: 190           # 硬限：自我退出交 systemd 重启
  fd_limit: 1024
  degraded_mode: true

executor:                    # M4 指令执行器
  enabled: true
  workers: 4                 # 并发执行 worker 数
  queue_size: 64             # 待执行队列容量（满则 REJECTED_BUSY）
  max_timeout: 300s          # 指令超时上限（平台超时不被信任为无上限）
  kill_grace: 3s             # SIGTERM 宽限后 SIGKILL 整个进程组
  output_limit_kb: 1024      # stdout/stderr 截断上限（头1/2+尾1/2）
  allow_test_actions: false  # 联调期可开：diagnose.test_sleep 验证超时查杀
